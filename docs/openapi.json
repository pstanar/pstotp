  "components": {
    "schemas": {
      "ApprovalAuth": {
        "required": [
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          }
        }
      },
      "ApproveDeviceRequest": {
        "required": [
          "approvalRequestId",
          "approvalAuth",
          "deviceEnvelope"
        ],
        "type": "object",
        "properties": {
          "approvalRequestId": {
            "type": "string",
            "format": "uuid"
          },
          "approvalAuth": {
            "$ref": "#/components/schemas/ApprovalAuth"
          },
