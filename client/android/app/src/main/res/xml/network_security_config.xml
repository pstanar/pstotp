<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security configuration for PsTotp.
  - Cleartext (HTTP) is blocked by default for security.
  - Exception for 10.0.2.2 (Android emulator localhost) for development.
  - Exception for localhost/127.0.0.1 for local testing.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />

    <!-- Allow cleartext for emulator localhost (development only) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
